# Zoom mode: mock (Ay 1 default) | real (Faz 2)
ZOOM_MODE=mock

# Faz 2 — leave empty for mock mode
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_SDK_KEY=
# ZOOM_SDK_SECRET=
# ZOOM_WEBHOOK_SECRET_TOKEN=
# ZOOM_WEBHOOK_VERIFICATION_TOKEN=

APP_BASE_URL=http://localhost:4010
WEBHOOK_CALLBACK_URL=http://localhost:4010/api/zoom/webhooks
PORT=4010
# Demo web (Vite): http://localhost:5174 — proxies /api to PORT above
NODE_ENV=development

# PostgreSQL (optional — in-memory store used when unset)
# DATABASE_URL=postgresql://zoom:zoom@localhost:5433/zoom_integration
