# Plaud (CI uses PLAUD_MODE=mock only — never live credentials in GitHub Actions)
PLAUD_MODE=mock
PLAUD_API_BASE_URL=
PLAUD_CLIENT_ID=
PLAUD_CLIENT_API_KEY=
# Webhook HMAC-SHA256 secret (x-plaud-signature header). Partner algorithm may differ in production.
PLAUD_WEBHOOK_SECRET=

# LLM (CI uses mock)
LLM_PROVIDER=mock
LLM_MODEL=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# API (default 3002). Web dev server: http://localhost:5174
PORT=3002
NODE_ENV=development
COMPANY_ID=company-iceberg-001
