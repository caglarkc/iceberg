{
  "name": "agent-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Iceberg Agent Stack POC: mission brief parser, scaffold generator, and handover package generator.",
  "type": "module",
  "bin": {
    "iceberg-agent": "./apps/cli/dist/src/index.js"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "node scripts/clean.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke": "bash scripts/smoke-test.sh",
    "scaffold": "node apps/cli/dist/src/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
