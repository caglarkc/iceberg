export function verifyWebhookSignature(signature: string | undefined): boolean {
  if (process.env.MOCK_API !== "false") return true;
  return Boolean(signature && signature.length > 16);
}

export function receiveWebhook(payload: unknown, signature?: string) {
  if (!verifyWebhookSignature(signature)) {
    throw new Error("Invalid webhook signature");
  }
  return { accepted: true, payload };
}
