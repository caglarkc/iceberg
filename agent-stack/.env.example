# LLM selection. CI must use mock.
LLM_PROVIDER=mock
LLM_MODEL=

# Optional provider credentials. Values are never required for scaffold fallback.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Optional Cursor SDK integration, intentionally not required by the POC.
CURSOR_API_KEY=YOUR_CURSOR_API_KEY_HERE
